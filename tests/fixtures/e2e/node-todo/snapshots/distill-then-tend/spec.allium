-- allium: 3
-- spec.allium

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

entity User {}

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

entity Todo {
    title: String
    owner: User?
    status: pending | done | archived | expired

    transitions status {
        pending -> done
        pending -> archived
        pending -> expired
        expired -> pending
        expired -> archived
        terminal: done, archived
    }

    due_at: Timestamp?
    created_at: Timestamp
    completed_at: Timestamp?
    archived_at: Timestamp?
    expired_at: Timestamp?
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    revive_grace: Duration = 7.days
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

rule CreateTodo {
    when: CreateTodo(owner, title, due_at?)

    requires: title != ""
    requires: due_at = null or due_at > now

    ensures: Todo.created(
        owner: owner,
        title: title,
        status: pending,
        due_at: due_at,
        created_at: now
    )
}

rule CompleteTodo {
    when: CompleteTodo(todo)

    requires: todo.status = pending

    ensures: todo.status = done
    ensures: todo.completed_at = now
}

rule ArchiveTodo {
    when: ArchiveTodo(todo)

    requires: todo.status not in {done, archived}

    ensures: todo.status = archived
    ensures: todo.archived_at = now
}

rule ReviveTodo {
    when: ReviveTodo(todo)

    requires: todo.status = expired
    requires: now - todo.expired_at <= config.revive_grace

    ensures: todo.status = pending
    ensures: todo.expired_at = null
}

rule ExpireOverdue {
    when: ExpireOverdue(todo)

    requires: todo.status = pending
    requires: todo.due_at != null
    requires: todo.due_at <= now

    ensures: todo.status = expired
    ensures: todo.expired_at = now
}

rule BulkArchive {
    when: BulkArchive(todos)

    requires: todos.all(t => t.status = pending)

    ensures:
        for t in todos:
            t.status = archived
            t.archived_at = now
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface TodoHttpApi {
    facing user: User

    provides:
        CreateTodo(user, title, due_at?)
        CompleteTodo(todo)
        ArchiveTodo(todo)
        ReviveTodo(todo)
        ExpireOverdue(todo)
        BulkArchive(todos)
}

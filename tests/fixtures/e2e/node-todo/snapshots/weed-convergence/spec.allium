-- allium: 3
-- spec.allium
-- Todo backend behavioural specification.
--
-- Scope: lifecycle of Todo entities (create, complete, archive, revive, expire)
-- and the HTTP boundary that drives them. The server transport itself
-- (routing, JSON shape, error-code-to-HTTP-status mapping) is implementation
-- detail and is not specified here.

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity Client {
    id: String
}

external entity Scheduler {
    id: String
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum TodoStatus { pending | done | archived | expired }

------------------------------------------------------------
-- Entities and Variants
------------------------------------------------------------

entity Todo {
    title: String
    owner: Client
    due_at: Timestamp?
    status: TodoStatus
    created_at: Timestamp
    completed_at: Timestamp?
    archived_at: Timestamp?
    expired_at: Timestamp?

    transitions status {
        pending -> done
        pending -> archived
        pending -> expired
        expired -> archived
        expired -> pending
        terminal: done, archived
    }

    is_overdue: due_at != null and due_at <= now
    is_revivable: status = expired and expired_at + config.revive_grace >= now
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    revive_grace: Duration = 7.days
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

rule CreateTodo {
    when: CreateTodo(client, title, due_at?)
    requires: length(title) > 0
    requires: length(trim(title)) > 0
    requires: due_at = null or due_at >= now
    ensures: Todo.created(
        owner: client,
        title: trim(title),
        due_at: due_at,
        status: pending,
        created_at: now
    )
}

rule CompleteTodo {
    when: CompleteTodo(client, todo)
    requires: todo.status = pending
    ensures: todo.status = done
    ensures: todo.completed_at = now
}

rule ArchiveTodo {
    when: ArchiveTodo(client, todo)
    requires: todo.status = pending or todo.status = expired
    ensures: todo.status = archived
    ensures: todo.archived_at = now

    @guidance
        -- When archiving from expired, the expiration marker is
        -- preserved: ArchiveTodo only sets archived_at and status, and
        -- does not clear expired_at. The combination status = archived
        -- with expired_at != null therefore records that the todo passed
        -- through expiration before archival, and is constrained by
        -- ExpirationTimestampImpliesExpiredOrArchived and
        -- ArchivedAfterExpired.
}

rule ReviveTodo {
    when: ReviveTodo(client, todo)
    requires: todo.status = expired
    requires: todo.expired_at + config.revive_grace >= now
    ensures: todo.status = pending
    ensures: todo.expired_at = null

    @guidance
        -- Revival does not modify due_at, created_at or any other
        -- lifecycle marker beyond clearing expired_at. A revived todo
        -- whose due date remains in the past will therefore be
        -- re-expired by the next ExpireOverdue evaluation. Repeated
        -- revive/expire cycles are permitted as long as each revival
        -- occurs within revive_grace of the most recent expiration; each
        -- re-expiration writes a fresh expired_at and restarts the grace
        -- window.
}

rule ExpireOverdue {
    when: todo: Todo.due_at <= now
    requires: todo.due_at != null
    requires: todo.status = pending
    ensures: todo.status = expired
    ensures: todo.expired_at = now

    @guidance
        -- The status = pending guard prevents the temporal trigger from
        -- re-firing on a todo already in the expired state: once status
        -- transitions to expired the trigger no longer matches, so the
        -- expiration is fire-once per pending cycle. After ReviveTodo
        -- returns the todo to pending with expired_at cleared, the
        -- trigger may match again and produce a fresh expiration if
        -- due_at remains in the past.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- Status-marker correlations. Each terminal or expired status implies
-- the corresponding timestamp marker is set. The code enforces this
-- because the only paths into these statuses set the marker in the same
-- step (see CompleteTodo, ArchiveTodo, ExpireOverdue).

invariant DoneHasCompletionTimestamp {
    for t in Todos: t.status = done implies t.completed_at != null
}

invariant ArchivedHasArchiveTimestamp {
    for t in Todos: t.status = archived implies t.archived_at != null
}

invariant ExpiredHasExpirationTimestamp {
    for t in Todos: t.status = expired implies t.expired_at != null
}

-- Converse correlations. The only path to setting completed_at is via
-- CompleteTodo, which transitions to done; done is terminal, so a
-- non-null completed_at implies status = done. Likewise archived_at is
-- only set by ArchiveTodo and archived is terminal.

invariant CompletionTimestampImpliesDone {
    for t in Todos: t.completed_at != null implies t.status = done
}

invariant ArchiveTimestampImpliesArchived {
    for t in Todos: t.archived_at != null implies t.status = archived
}

-- ArchiveTodo from expired preserves expired_at (it sets archived_at
-- and the new status, but does not clear the prior expiration marker).
-- ReviveTodo clears expired_at on the way back to pending. So a
-- non-null expired_at implies the todo is either currently expired or
-- was expired before being archived.

invariant ExpirationTimestampImpliesExpiredOrArchived {
    for t in Todos: t.expired_at != null implies (t.status = expired or t.status = archived)
}

-- Title shape. CreateTodo rejects empty/whitespace-only titles and stores
-- trim(title); no other rule mutates title, so every persisted Todo
-- carries a non-empty, surrounding-whitespace-free title for the life of
-- the entity. Clients reading title via TodoLifecycleApi may rely on this.

invariant TitleNonEmpty {
    for t in Todos: length(t.title) > 0
}

invariant TitleTrimmed {
    for t in Todos: t.title = trim(t.title)
}

-- Expiration is gated on due date. ExpireOverdue is the only rule that
-- sets expired_at, and it requires due_at != null. due_at is set at
-- creation and is never mutated by any subsequent rule (ReviveTodo and
-- ArchiveTodo leave it untouched), so the presence of an expiration
-- marker implies the todo has carried a due date for its entire life.

invariant ExpirationTimestampImpliesDueDate {
    for t in Todos: t.expired_at != null implies t.due_at != null
}

-- Lifecycle timestamp ordering. created_at is fixed at entity creation;
-- every other lifecycle marker (completed_at, archived_at, expired_at)
-- is set by a mutating rule that necessarily runs strictly after the
-- creating rule. Each non-null marker is therefore at or after
-- created_at on the same todo.

invariant CompletionTimestampAfterCreation {
    for t in Todos: t.completed_at != null implies t.created_at <= t.completed_at
}

invariant ArchiveTimestampAfterCreation {
    for t in Todos: t.archived_at != null implies t.created_at <= t.archived_at
}

invariant ExpirationTimestampAfterCreation {
    for t in Todos: t.expired_at != null implies t.created_at <= t.expired_at
}

-- Relative ordering between expiration and archival. When a todo is
-- archived from the expired state, ArchiveTodo runs strictly after the
-- ExpireOverdue that set expired_at. The two timestamps come from
-- sequential evaluations of now, so when both markers are present the
-- expiration precedes (or coincides with) the archival.

invariant ArchivedAfterExpired {
    for t in Todos: (t.archived_at != null and t.expired_at != null) implies t.expired_at <= t.archived_at
}

-- Due date follows creation. CreateTodo rejects past due dates
-- (due_at >= now) and binds created_at to the same now in the same
-- rule evaluation; due_at is never mutated by any subsequent rule.
-- So whenever a due date is set, it lies at or after the todo's
-- creation for the life of the entity.

invariant DueDateAtLeastCreation {
    for t in Todos: t.due_at != null implies t.created_at <= t.due_at
}

-- Due date precedes expiration. ExpireOverdue is the only rule that
-- sets expired_at, and its temporal trigger fires only once due_at has
-- elapsed (due_at <= now); the ensures clause binds expired_at to that
-- same now. due_at is never mutated by any subsequent rule, so the
-- relation persists for the life of the entity.

invariant DueDateAtMostExpiration {
    for t in Todos: t.expired_at != null implies t.due_at <= t.expired_at
}

-- Lifecycle marker mutual exclusion. completed_at, archived_at and
-- expired_at each pin the status to a disjoint subset of TodoStatus
-- (done; archived; expired-or-archived). Combined with status being a
-- single enum value at any point in time, certain marker pairings are
-- structurally impossible and are surfaced explicitly here so callers
-- reading a Todo over TodoLifecycleApi need not re-derive them.
--
-- - completed_at and archived_at cannot both be set: completed_at
--   forces status = done, archived_at forces status = archived, and
--   both are terminal, so the entity could never have visited both.
-- - completed_at and expired_at cannot both be set: completed_at
--   forces status = done; expired_at forces expired or archived;
--   done is disjoint from both, so the conjunction is unreachable.

invariant CompletionAndArchivalAreExclusive {
    for t in Todos: not (t.completed_at != null and t.archived_at != null)
}

invariant CompletionAndExpirationAreExclusive {
    for t in Todos: not (t.completed_at != null and t.expired_at != null)
}

-- Pending-state cleanliness. The two paths into status = pending are
-- entity creation (CreateTodo, which sets only created_at) and
-- ReviveTodo (which clears expired_at on the way back from expired).
-- No path into pending sets completed_at, archived_at or expired_at;
-- and CompletionTimestampImpliesDone / ArchiveTimestampImpliesArchived
-- forbid those markers from coexisting with status = pending. This
-- combination is restated explicitly so the property is visible to
-- callers reading a pending Todo without chasing through the
-- contrapositives of three separate invariants.

invariant PendingHasNoTerminalMarkers {
    for t in Todos: t.status = pending implies (
        t.completed_at = null
        and t.archived_at = null
        and t.expired_at = null
    )
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface TodoLifecycleApi {
    facing client: Client

    context todo: Todo where owner = client

    exposes:
        todo.title
        todo.owner
        todo.status
        todo.due_at
        todo.created_at
        todo.completed_at
        todo.archived_at
        todo.expired_at
        todo.is_overdue
        todo.is_revivable

    provides:
        CompleteTodo(client, todo) when todo.status = pending
        ArchiveTodo(client, todo) when todo.status = pending or todo.status = expired
        ReviveTodo(client, todo) when todo.is_revivable

    timeout:
        ExpireOverdue when todo.due_at <= now

    @guidance
        -- Surface invocations that address a todo by identifier
        -- presuppose the addressed todo exists and falls within the
        -- context filter (owner = client). The implementation rejects
        -- invocations against unknown identifiers at the boundary
        -- before any rule fires, separately from the rule's own
        -- requires-clause violations.
        --
        -- The `where owner = client` filter is declarative intent. The
        -- current implementation does not enforce caller-to-owner
        -- binding at the HTTP boundary (no authentication or
        -- authorization layer is present); any caller can address any
        -- todo via its identifier. Treat the ownership filter as the
        -- intended behaviour once an authentication layer is
        -- introduced, not as a property the present implementation
        -- guarantees.
        --
        -- The derived predicates exposed here (todo.is_overdue,
        -- todo.is_revivable) describe properties intrinsic to the
        -- todo's lifecycle state. The current implementation's read
        -- entry point returns the persisted lifecycle fields verbatim
        -- (title, owner, status, due_at, created_at, completed_at,
        -- archived_at, expired_at) and does not compute these derived
        -- values server-side; callers receive the inputs (due_at,
        -- status, expired_at and the revive_grace config value) and
        -- may recompute the predicates locally against their own
        -- clock. Treat the surface-level exposure of derived values
        -- as the intended behaviour once the read entry point computes
        -- them, not as a property the present implementation
        -- guarantees.
}

surface TodoCollectionApi {
    facing client: Client

    provides:
        CreateTodo(client, title, due_at?)

    @guidance
        -- The `facing client: Client` binding is declarative intent. The
        -- current implementation accepts the client identity verbatim
        -- from the request payload alongside the title and due date,
        -- with no authentication layer in place to verify the caller is
        -- in fact the named client. Any caller able to reach the
        -- creation entry point can therefore create a todo on behalf of
        -- any client identifier. Treat the caller-to-client binding as
        -- the intended behaviour once an authentication layer is
        -- introduced, not as a property the present implementation
        -- guarantees.
}

surface TodoExpirationSweep {
    facing scheduler: Scheduler

    context todo: Todo

    timeout:
        ExpireOverdue when todo.due_at <= now

    @guidance
        -- Realised in practice as a scheduler/admin-triggered batch sweep
        -- that iterates pending todos and applies ExpireOverdue to any
        -- whose due date has passed. The temporal trigger fires per todo
        -- regardless of how evaluation is initiated. This surface
        -- represents the externally-driven evaluation path; the same
        -- temporal trigger is also surfaced per-todo to clients on
        -- TodoLifecycleApi.
        --
        -- Each sweep invocation yields, as an observable side-channel
        -- to the calling scheduler, the set of todos whose status
        -- transitioned to expired during that invocation. This is a
        -- batch-outcome convenience for callers that wish to audit or
        -- react to the result of a sweep. It is not modelled as a
        -- spec-level interaction because no rule depends on its
        -- presence; the per-todo state changes are the authoritative
        -- behavioural effect. The batch-result transport is
        -- implementation detail (it appears in the current
        -- implementation as a list of todo identifiers in the
        -- response body of POST /todos/expire).
        --
        -- The current implementation does not enforce that the
        -- caller of the sweep entry point is in fact a Scheduler;
        -- the actor binding is declarative intent. Any caller able
        -- to reach the sweep entry point can trigger evaluation.
}

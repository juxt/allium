          {"kind": "assign", "lhs": "claim.status", "rhs": "assessing"},
          {"kind": "create", "entity": "Assessment", "fields": {"assessor": "assessor", "claim": "claim", "findings": "\"\"", "started_at": "now", "status": "in_progress"}}

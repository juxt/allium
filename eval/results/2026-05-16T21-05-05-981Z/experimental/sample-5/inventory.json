          {"kind": "create", "entity": "Payout", "fields": {"amount_pence": "claim.amount_claimed_pence", "claim": "claim", "failed_attempts": "0", "scheduled_at": "now", "status": "scheduled"}}
        ]
      },
      "guidance": null
    },
    {

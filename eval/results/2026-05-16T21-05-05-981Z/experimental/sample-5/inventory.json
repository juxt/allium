    {
      "method": "GET",
      "path": "/policies/<policy_number>/claims",
      "handler": "list_policy_claims_route",
      "module": "app/routes.py"
    }
  ],
  "webhooks": [
    {
      "path": "/webhooks/incident-reports",
      "produces_entity": "IncidentReport",
      "linking_rule": "match by policy and incident-date proximity within config.link_window"
    }
  ]
}

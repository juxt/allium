        {"name": "claim", "type_hint": "Claim", "nullable": false},
        {"name": "failed_attempts", "type_hint": "Integer", "nullable": false},
        {"name": "last_failure_at", "type_hint": "Timestamp?", "nullable": true},
        {"name": "paid_at", "type_hint": "Timestamp?", "nullable": true},
        {"name": "scheduled_at", "type_hint": "Timestamp", "nullable": false},
        {"name": "status", "type_hint": "PayoutStatus", "nullable": false}
      ],
      "status_enum": {"name": "PayoutStatus", "values": ["scheduled", "paid", "failed"]},
      "relationships": [],
      "derived_properties": [
        {"name": "retry_due_at", "expression": "coalesce(last_failure_at, scheduled_at) + config.payout_retry_after"}
      ],
      "guidance": null
    },
    {
      "name": "Policy",
      "kind": "internal",
      "fields": [

            "kind": "invoke",
            "trigger": "approve_claim"
          }
        ],
        "post_invocations": [],
        "requires": [
          "\"trusted\" in claim.policy.holder_tags",
          "claim.amount_claimed_pence < config.auto_approve_max_pence",
          "claim.status = assessing"
        ],
        "when": "claim: Claim.has_completed_assessment"
      },
      "guidance": "Auto-approves low-value claims for trusted holders once their assessment is completed, sparing the adjuster a manual click-through",
      "name": "auto_approval_scheduler"
    },
    {
      "body": {
        "ensures": [
          {
            "kind": "assign",
            "lhs": "claim.status",
            "rhs": "closed"
          },

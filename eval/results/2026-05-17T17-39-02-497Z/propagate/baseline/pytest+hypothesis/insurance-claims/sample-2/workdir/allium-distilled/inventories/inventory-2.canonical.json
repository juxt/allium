    {
      "body": {
        "ensures": [],
        "post_invocations": [],
        "requires": [
          "claim.status in {triaged, assessing}"
        ],
        "when": "claim: Claim.submitted_at + config.assessment_sla <= now"
      },
      "guidance": "Surfaces claims that have breached the 14-day assessment SLA. Read-only — produces a list, does not mutate state.",
      "name": "assessment_sla_job"
    },
    {
      "body": {
        "ensures": [
          {

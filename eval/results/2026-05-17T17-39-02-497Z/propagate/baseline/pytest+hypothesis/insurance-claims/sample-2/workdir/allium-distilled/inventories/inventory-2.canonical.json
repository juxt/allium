            "lhs": "claim.last_activity_at",
            "rhs": "now"
          }
        ],
        "post_invocations": [],
        "requires": [
          "claim.status = denied"
        ],
        "when": "claim: Claim.last_activity_at + config.auto_close_denied_after <= now"
      },
      "guidance": "Closes denied claims that have had no activity for 90 days",
      "name": "auto_close_denied_job"
    },
    {
      "body": {
        "ensures": [
          {
            "args": {
              "account_number": "\"00000000\"",
              "amount_pence": "payout.amount_pence",
              "reference": "payout.payout_id",
